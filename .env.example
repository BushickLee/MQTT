MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=risk-alert-bridge
MQTT_USERNAME=
MQTT_PASSWORD=

MQTT_RAW_TOPIC=risk/alerts/raw
MQTT_GUARDIAN_TOPIC=risk/alerts/guardian
MQTT_OS_BACKGROUND_TOPIC=notifications/os-background
MQTT_IN_APP_TOPIC=notifications/in-app
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_CONNECT_RETRY_SECONDS=3
MQTT_SUPPRESS_REPEATED_PHASE=true
MQTT_PUBLISH_NORMAL_EVENTS=false
MQTT_EARLY_WARNING_CONFIDENCE_THRESHOLD=0.65
MQTT_DANGER_CONFIDENCE_THRESHOLD=0.60
MQTT_EARLY_WARNING_CONSECUTIVE_COUNT=2

MQTT_DEFAULT_HLS_URL=http://localhost:8000/static/live/stream.m3u8
MQTT_DEFAULT_THUMBNAIL_URL=
